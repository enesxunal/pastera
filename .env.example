# Kopyala: cp .env.example .env.local

ADMIN_PASSWORD=
BRANCH_PANEL_PASSWORD=
DISPLAY_ACCESS_KEY=
# Salon ekranı (boşsa DISPLAY_ACCESS_KEY kullanılır)
LOBBY_ACCESS_KEY=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Termal fiş: 58 veya 80 (mm)
NEXT_PUBLIC_RECEIPT_WIDTH_MM=80
SUPABASE_SERVICE_ROLE_KEY=

BRANCH_PANEL_BRANCH_ID=

# Vercel cron (/api/cron/backup) — rastgele uzun bir değer
CRON_SECRET=

# Canlı site (Vercel vb.) — aynı API ileride mobil uygulama (app) için de kullanılır
NEXT_PUBLIC_SITE_URL=https://pastera.de

# Coming soon: sadece COMING_SOON=true ise açılır
# COMING_SOON=true

# Paket servisi (Lieferung) — varsayılan kapalı. Açmak için:
# NEXT_PUBLIC_DELIVERY_ENABLED=true

# Online sipariş (gel-al, masada, sepet) — varsayılan kapalı. Açmak için:
# NEXT_PUBLIC_ONLINE_ORDERING_ENABLED=true

# PayPal — test: PAYPAL_MODE=sandbox | canlı: PAYPAL_MODE=live
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Resend — sipariş mailleri (Supabase SMTP ile aynı API key olabilir)
RESEND_API_KEY=
PASTERA_EMAIL_FROM=Pastera <noreply@pastera.de>
PASTERA_GOOGLE_REVIEW_URL=https://share.google/oM2PvWB3FpOcxjQHt
